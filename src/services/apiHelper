/*apiHelper*/
import { enrichPostsWithUserData } from "../utils/postsUtils.js"
import { usersData } from "../services/mocks/users.mock.js"
import { postsData } from "../services/mocks/post.mock.js"

export function get() {
    return fetch("/users.mock.json").then(response => response.json());
}

export function getPosts({ page = 1, limit = 10 } = {}) {
    const allPosts = enrichPostsWithUserData(postsData, usersData);

    const start = (page - 1) * limit;
    const end = start + limit;
    const data = allPosts.slice(start, end);

    return Promise.resolve({
        data,
        pagination: {
            currentPage: page,
            totalPages: Math.ceil(allPosts.length / limit),
        }
    });
}